# === LLM Configuration ===
# Default: uses Anthropic Claude. Set LLM_PROVIDER to switch.

# Option 1: Anthropic (default)
LLM_PROVIDER=anthropic
LLM_API_KEY=your-api-key-here
# LLM_MODEL=claude-sonnet-4-20250514

# Option 2: OpenAI
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o

# Option 3: Google Gemini (via OpenAI-compatible endpoint)
# LLM_PROVIDER=openai
# LLM_API_KEY=your-gemini-api-key
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# LLM_MODEL=gemini-2.0-flash

# Option 4: Local models (Ollama, LM Studio, etc.)
# LLM_PROVIDER=openai
# LLM_API_KEY=unused
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3

# Legacy: still works if you only set this (treated as Anthropic)
# ANTHROPIC_API_KEY=your-api-key-here

# === Email notifications ===
NOTIFICATION_EMAIL=the-email-id-where-notifications-go@emailprovider.com
SENDER_EMAIL=the-email-id-where-notifications-come-from@emailprovider.com

# === General ===
# LOK_SABHA_NUMBER=18
# DATA_DIR=/path/to/data
